#!/usr/bin/env python3
"""
手机识别优化配置
"""

class PhoneConfig:
    # 系统设置
    DEBUG_MODE = True
    LOG_LEVEL = "INFO"

    # 摄像头设置
    CAMERA_ID = 0
    FRAME_WIDTH = 640
    FRAME_HEIGHT = 480
    FPS = 15
    FLIP_HORIZONTAL = True

    # 检测设置
    MODEL_NAME = 'yolov5s'  # 使用更大的模型以提高准确性
    CONFIDENCE_THRESHOLD = 0.35  # 手机检测需要更低的阈值
    IOU_THRESHOLD = 0.4

    # 手机特定设置
    PHONE_CLASS_IDS = [67]  # YOLOv5中cell phone通常是67
    MIN_PHONE_SIZE = 15     # 手机通常比人脸小
    MAX_PHONE_SIZE = 400

    # 图像增强设置（提高手机检测率）
    ENHANCE_CONTRAST = True
    BRIGHTNESS_FACTOR = 1.2
    CONTRAST_FACTOR = 1.3

    # 追踪设置
    TRACKING_ENABLED = True
    TRACKING_SMOOTHING = 0.3
    MAX_TRACK_LOSS = 20

    # 显示设置
    DRAW_PHONE_BBOX = True
    DRAW_TRACKING_PATH = True
    SHOW_CONFIDENCE = True

    # 保存设置
    SAVE_DETECTIONS = True
    SAVE_PATH = "phone_results"

    @staticmethod
    def enhance_image(image):
        """增强图像以提高手机检测率"""
        if not PhoneConfig.ENHANCE_CONTRAST:
            return image
    
        # 转换为YUV颜色空间
        yuv = cv2.cvtColor(image, cv2.COLOR_BGR2YUV)
    
        # 对亮度通道应用直方图均衡化
        yuv[:,:,0] = cv2.equalizeHist(yuv[:,:,0])
    
        # 转换回BGR
        enhanced = cv2.cvtColor(yuv, cv2.COLOR_YUV2BGR)
    
        # 调整亮度和对比度
        enhanced = cv2.convertScaleAbs(enhanced, 
                                      alpha=PhoneConfig.CONTRAST_FACTOR, 
                                      beta=PhoneConfig.BRIGHTNESS_FACTOR * 10)
    
        return enhanced
EOF
```

